// Prisma Schema for Overwatch Homelab
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceType {
  HOMELAB
  SERVER
  PC
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  password           String
  recoveryTokenHash  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  homelabs HomeLab[]

  @@map("users")
}

model HomeLab {
  id                  String       @id @default(uuid())
  name                String
  description         String?
  resourceType        ResourceType @default(HOMELAB)
  labels              String[]     @default([])
  ownerId             String
  agentHubUrl         String?
  heartbeatIntervalMs Int          @default(15000)
  metricsIntervalMs   Int          @default(60000)
  retentionDays       Int          @default(30)
  alertThresholds     Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  owner     User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  snapshots MetricSnapshot[]
  alerts    Alert[]

  @@index([ownerId, createdAt])
  @@map("homelabs")
}

model MetricSnapshot {
  id              String   @id @default(uuid())
  labId           String
  recordedAt      DateTime @default(now())
  cpuPercent      Float
  memTotalBytes   BigInt
  memActiveBytes  BigInt
  diskSnapshots   Json
  rawPayload      Json

  lab HomeLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, recordedAt(sort: Desc)])
  @@map("metric_snapshots")
}

enum AlertMetric {
  cpu
  memory
  disk
}

model Alert {
  id             String      @id @default(uuid())
  labId          String
  metric         AlertMetric
  threshold      Float
  peakValue      Float
  firedAt        DateTime    @default(now())
  resolvedAt     DateTime?
  acknowledgedAt DateTime?

  lab HomeLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@index([labId, firedAt(sort: Desc)])
  @@map("alerts")
}
