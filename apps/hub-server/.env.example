# Hub Server Environment Variables
# All required vars are validated at startup — the server refuses to boot
# with a clear error if any are missing or malformed.

# Server
PORT=3001
NODE_ENV=development

# Database (required)
DATABASE_URL="postgresql://overwatch:overwatch_pass@localhost:5432/overwatch_db"

# JWT (required) — generate with: openssl rand -hex 32
# Minimum 16 characters. Never commit a real secret to source control.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# CORS (required) — must be a full URL including scheme
CORS_ORIGIN=http://localhost:5173
