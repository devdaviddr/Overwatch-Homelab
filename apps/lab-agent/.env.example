# Lab Agent Environment Variables

# The Hub Server WebSocket URL
HUB_URL=http://localhost:3001

# The unique ID of the HomeLab this agent is managing (UUID from DB)
LAB_ID=replace-with-your-homelab-uuid

# How often to send heartbeats (milliseconds)
HEARTBEAT_INTERVAL_MS=15000

# How often to report metrics (milliseconds)
METRICS_INTERVAL_MS=60000
