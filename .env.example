# Root-level docker-compose environment — copy to .env for local dev.
#   cp .env.example .env
#   # then replace the placeholder below with:  openssl rand -hex 32
#
# docker-compose auto-loads .env from the project root. hub-server
# refuses to start if JWT_SECRET is missing or shorter than 16 chars.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Only required when starting the dockerised lab-agent profile:
#   docker compose --profile agent up -d
# Create a HomeLab in the dashboard first, copy its UUID here.
# Default `docker compose up` does NOT require LAB_ID.
LAB_ID=
